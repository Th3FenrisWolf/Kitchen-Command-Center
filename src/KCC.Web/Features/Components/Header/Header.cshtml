@using KCC.Web.Features.Components.Header
@using KCC.Web.Features.Models.Common

@model HeaderViewModel

<AppHeader
  home-url="@Url.Content("~/")"
  :logo="@Vue.Prop(Model.Logo)"
  :main-nav-items="@Vue.Prop(Model.MainNavItems)"
  :utility-nav-items="@Vue.Prop(Model.UtilityNavItems.Append(new()
  {
    DisplayText = "Login",
    SubLinks = new[]
    {
      new PageLink
      {
        DisplayText = "Login",
        Url = "/Account/Login",
      },
    },
  }))"
/>
