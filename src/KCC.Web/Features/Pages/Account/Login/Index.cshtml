@using KCC.Web.Features.Helpers
@using KCC.Web.Features.Pages.Account.Login

@model LoginViewModel

<LoginView
  return-url="@Model.ReturnUrl"
  default-user-name="@Model.UserName"
  default-password="@Model.Password"
  :default-remember-me="@Model.RememberMe"
  :resource-strings="@Vue.Prop(Model.ResourceStrings)"
/>
