@using KCC.Web.Features.Helpers
@using KCC.Web.Features.Pages.VariantDetail

@model VariantDetailViewModel

<VariantDetailView
  variant-name="@Model.VariantName"
  variant-description="@Model.VariantDescription"
  icon="@Model.Icon"
  :images="@Vue.Prop(Model.Images)"
  :prep-time="@Vue.Prop(Model.PrepTime)"
  :cook-time="@Vue.Prop(Model.CookTime)"
  :servings="@Vue.Prop(Model.Servings)"
  difficulty="@Model.Difficulty"
  :calories="@Vue.Prop(Model.Calories)"
  :protein-g="@Vue.Prop(Model.ProteinG)"
  :carbs-g="@Vue.Prop(Model.CarbsG)"
  :fat-g="@Vue.Prop(Model.FatG)"
  :saturated-fat-g="@Vue.Prop(Model.SaturatedFatG)"
  :fiber-g="@Vue.Prop(Model.FiberG)"
  :sugar-g="@Vue.Prop(Model.SugarG)"
  :sodium-mg="@Vue.Prop(Model.SodiumMg)"
  :tags="@Vue.Prop(Model.Tags)"
  :ingredients="@Vue.Prop(Model.Ingredients)"
  :instructions="@Vue.Prop(Model.Instructions)"
  recipe-name="@Model.RecipeName"
  recipe-slug="@Model.RecipeSlug"
  created-by-name="@Model.CreatedByName"
  :variant-guid="@Vue.Prop(Model.VariantGuid)"
  :average-rating="@Vue.Prop(Model.AverageRating)"
  :review-count="@Vue.Prop(Model.ReviewCount)"
  :cooked-count="@Vue.Prop(Model.CookedCount)"
  :has-cooked="@Vue.Prop(Model.HasCooked)"
  :is-authenticated="@Vue.Prop(Model.IsAuthenticated)"
  :breadcrumbs="@Vue.Prop(Model.Breadcrumbs)"
  :sibling-variants="@Vue.Prop(Model.SiblingVariants)"
  :resource-strings="@Vue.Prop(Model.ResourceStrings)"
/>
